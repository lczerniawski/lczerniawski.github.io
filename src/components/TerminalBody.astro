---
interface Props {
  terminalPath: string;
  isSearchable: boolean;
}

const { terminalPath, isSearchable = false } = Astro.props;
---

<div class="terminal-body">
  <div class="terminal-prompt-container">
    <div
      class="terminal-prompt"
      id="terminal-prompt-line"
      class:list={{ "clickable-prompt": isSearchable }}
    >
      <span id="prompt-static-text" class="terminal-prompt-text"
        >$ open {terminalPath}</span
      >

      {
        isSearchable && (
          <div
            id="prompt-interactive-search"
            class="search-input-wrapper"
            style="display: none;"
          >
            <span class="terminal-prompt-text">$ search</span>
            <input
              type="text"
              id="layout-terminal-search"
              placeholder="grep entries..."
              autocomplete="off"
            />
          </div>
        )
      }

      <span class="terminal-cursor" id="prompt-cursor" aria-hidden="true"
      ></span>
    </div>

    {
      isSearchable && (
        <span class="search-hint-msg" id="search-hint">
          [Tip: Click prompt or press CMD/Ctrl+F or press Enter to search posts,
          ESC to exit search.]
        </span>
      )
    }
  </div>
  <div class="frame-content">
    <slot />
  </div>

  <style>
    .terminal-body {
      padding: 24px 32px 32px;
    }

    .terminal-prompt-container {
      display: block;
      gap: 12px;
      margin-bottom: 18px;
      border-bottom: 1px dashed var(--border-color);
      padding-bottom: 10px;
    }

    .terminal-prompt {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--accent-color);
      font-size: 12px;
      flex-grow: 1;
    }

    .clickable-prompt {
      cursor: pointer;
    }
    .search-input-wrapper {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
    }

    #layout-terminal-search {
      background: transparent;
      border: none;
      color: var(--text-light);
      font-family: var(--font-mona);
      font-size: 12px;
      outline: none;
      flex-grow: 1;
      padding: 0;
      caret-color: var(--accent-color);
    }

    .search-hint-msg {
      font-size: 11px;
      color: var(--text-muted);
      opacity: 0.7;
    }
    .terminal-prompt-text {
      min-width: 0;
      overflow-wrap: anywhere;
    }
    .terminal-cursor {
      width: 8px;
      height: 20px;
      background: var(--accent-color);
      animation: blink 1s steps(1, end) infinite;
      flex: none;
    }
    @keyframes blink {
      0%,
      50% {
        opacity: 1;
      }
      51%,
      100% {
        opacity: 0;
      }
    }

    .frame-content h1,
    .frame-content h2,
    .frame-content h3 {
      color: var(--text-light);
      margin-top: 24px;
      margin-bottom: 12px;
    }

    .frame-content p {
      color: var(--text-light);
      margin: 12px 0;
    }

    .frame-content a {
      color: var(--link-text);
      text-decoration: none;
      border-bottom: 1px dotted var(--link-text);
    }

    .frame-content a:hover {
      color: var(--link-hover);
    }

    .frame-content code {
      background: var(--code-bg);
      padding: 2px 6px;
      font-size: 13px;
      color: var(--code-text);
    }

    @media (max-width: 768px) {
      .terminal-body {
        padding: 16px 20px 20px;
      }
    }
  </style>
</div>

<script>
  import { searchQuery } from "../store";

  function initSearchTerminal() {
    const promptLine = document.getElementById("terminal-prompt-line");
    const staticText = document.getElementById("prompt-static-text");
    const searchWrapper = document.getElementById("prompt-interactive-search");
    const searchInput = document.getElementById(
      "layout-terminal-search",
    ) as HTMLInputElement;
    const customCursor = document.getElementById("prompt-cursor");
    const searchHint = document.getElementById("search-hint");

    if (!promptLine || !searchInput) return;

    // Activates Search Mode
    function activateTerminalSearch() {
      if (staticText) staticText.style.display = "none";
      if (customCursor) customCursor.style.display = "none";
      if (searchHint) searchHint.style.display = "none";
      if (searchWrapper) searchWrapper.style.display = "flex";

      searchInput.focus();
    }

    // Deactivates Search Mode & resets visibility filters
    function deactivateTerminalSearch() {
      searchInput.value = ""; // Reset query value
      searchQuery.set("");

      if (staticText) staticText.style.display = "inline";
      if (customCursor) customCursor.style.display = "inline-block";
      if (searchHint) searchHint.style.display = "inline";
      if (searchWrapper) searchWrapper.style.display = "none";
    }

    // 1. Toggle Active State on Prompt Click
    promptLine.addEventListener("click", (e) => {
      e.stopPropagation();
      activateTerminalSearch();
    });

    // 2. Escape Key Listener & Hotkey combinations
    document.addEventListener("keydown", (e) => {
      const isSearchShortcut =
        (e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "f";
      const isEnterKey = e.key === "Enter";

      if (isSearchShortcut || isEnterKey) {
        e.preventDefault();
        activateTerminalSearch();
      }

      if (e.key === "Escape") {
        deactivateTerminalSearch();
      }
    });

    searchInput.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      const query = target.value.toLowerCase().trim();
      searchQuery.set(query);
    });
  }

  document.addEventListener("astro:page-load", initSearchTerminal);
</script>
