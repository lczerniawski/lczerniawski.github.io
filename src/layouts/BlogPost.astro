---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import Layout from "./Layout.astro";
import {
  absoluteUrl,
  pageNodeId,
  siteNodeId,
  siteRootUrl,
  type JsonLdNode,
} from "../lib/jsonld";

type Props = CollectionEntry<"blog">["data"] & { slug: string };

const { title, description, pubDate, updatedDate, heroImage, slug } = Astro.props;
const siteUrl = Astro.site!;
const pagePath = `/blog/${slug}/`;
const pageUrl = absoluteUrl(siteUrl, pagePath);
const websiteId = siteNodeId(siteUrl, "#website");
const personId = siteNodeId(siteUrl, "#person");
const blogId = siteNodeId(siteUrl, "#blog");
const webpageId = pageNodeId(siteUrl, pagePath, "#webpage");
const breadcrumbId = pageNodeId(siteUrl, pagePath, "#breadcrumb");

const structuredData: JsonLdNode[] = [
  {
    "@type": "WebSite",
    "@id": websiteId,
    url: siteRootUrl(siteUrl),
    name: "lczerniawski",
    publisher: {
      "@id": personId,
    },
  },
  {
    "@type": "Person",
    "@id": personId,
    url: siteRootUrl(siteUrl),
    name: "Łukasz Czerniawski",
    alternateName: "lczerniawski",
    givenName: "Łukasz",
    familyName: "Czerniawski",
    jobTitle: "Solution Architect",
    description:
      "Solution Architect at AXA focused on security, .NET engineering, Python and applied AI.",
    knowsLanguage: "en-GB",
    image: {
      "@type": "ImageObject",
      "@id": siteNodeId(siteUrl, "#person-image"),
      url: absoluteUrl(siteUrl, "/lukasz_czerniawski_photo.jpg"),
      caption: "Łukasz Czerniawski",
    },
    sameAs: [
      "https://github.com/lczerniawski",
      "https://www.linkedin.com/in/lczerniawski",
    ],
  },
  {
    "@type": "WebPage",
    "@id": webpageId,
    url: pageUrl,
    isPartOf: {
      "@id": websiteId,
    },
    name: title,
    inLanguage: "en-GB",
    breadcrumb: {
      "@id": breadcrumbId,
    },
    mainEntity: {
      "@id": pageNodeId(siteUrl, pagePath, "#blogposting"),
    },
  },
  {
    "@type": "BreadcrumbList",
    "@id": breadcrumbId,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteRootUrl(siteUrl),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: absoluteUrl(siteUrl, "/blog/"),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: title,
        item: pageUrl,
      },
    ],
  },
  {
    "@type": "BlogPosting",
    "@id": pageNodeId(siteUrl, pagePath, "#blogposting"),
    url: pageUrl,
    mainEntityOfPage: {
      "@id": webpageId,
    },
    isPartOf: {
      "@id": blogId,
    },
    headline: title,
    description,
    inLanguage: "en-GB",
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: {
      "@id": personId,
    },
    publisher: {
      "@id": personId,
    },
    ...(heroImage
      ? {
          image: {
            "@type": "ImageObject",
            "@id": pageNodeId(siteUrl, pagePath, "#blogposting-image"),
            url: absoluteUrl(siteUrl, heroImage.src),
            width: heroImage.width,
            height: heroImage.height,
          },
        }
      : {}),
  },
  {
    "@type": "Blog",
    "@id": blogId,
    isPartOf: {
      "@id": websiteId,
    },
    mainEntityOfPage: {
      "@id": absoluteUrl(siteUrl, "/blog/#webpage"),
    },
    name: "lczerniawski Blog",
    description:
      "Technical blog of Łukasz Czerniawski about security, architecture, .NET, Python, and applied AI.",
    inLanguage: "en-GB",
    publisher: {
      "@id": personId,
    },
  },
];
---

<Layout
  title={title}
  description={description}
  jsonLd={structuredData}
  ogType="article"
  ogImage={heroImage ? heroImage.src : "/lukasz_czerniawski_photo.jpg"}
  ogImageAlt={heroImage ? title : "Łukasz Czerniawski portrait"}
  ogImageWidth={heroImage ? heroImage.width : undefined}
  ogImageHeight={heroImage ? heroImage.height : undefined}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
>
  <article class="blog-article">
    {
      heroImage && (
        <div class="hero-image">
          <Image width={1020} height={510} src={heroImage} alt={title} />
        </div>
      )
    }
    <div class="prose">
      <div class="blog-meta">
        <div class="date">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <div class="last-updated-on">
                Last updated on <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        <h1>{title}</h1>
      </div>
      <slot />
    </div>
  </article>
</Layout>

<style>
  .blog-article {
    width: 100%;
  }

  .hero-image {
    margin-bottom: 24px;
    overflow: hidden;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .prose {
    color: var(--text-light);
    line-height: 1.8;
  }

  .blog-meta {
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
  }

  .date {
    font-size: 12px;
    color: var(--text-muted);
  }

  .last-updated-on {
    font-style: italic;
    margin-top: 4px;
    font-size: 11px;
  }
</style>
