---
import { ClientRouter } from "astro:transitions";
import Navigation from "../components/Navigation.astro";
import "../styles/global.css";
import { SITE_TITLE } from "../consts";
import { Font } from "astro:assets";
import BackToTop from "../components/BackToTop.astro";
import TerminalBody from "../components/TerminalBody.astro";

interface Props {
  title: string;
  description: string;
  isSearchable?: boolean;
  jsonLd?: JsonLdNode[];
  ogType?: "website" | "profile" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  profileFirstName?: string;
  profileLastName?: string;
  profileUsername?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

type JsonLdNode = Record<string, unknown>;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title,
  description,
  isSearchable = false,
  jsonLd = [],
  ogType = "website",
  ogImage,
  ogImageAlt = title,
  ogImageWidth,
  ogImageHeight,
  profileFirstName,
  profileLastName,
  profileUsername,
  publishedTime,
  modifiedTime,
} = Astro.props;
const terminalPath = `~${Astro.url.pathname}`;
const finalTitle = `${SITE_TITLE} - ${title}`;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<html lang="en">
  <head>
    <!-- Global Metadata -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL("rss.xml", Astro.site)}
    />
    <meta name="generator" content={Astro.generator} />

    <Font cssVariable="--font-mona" preload />

    <!-- Apply theme before page renders to prevent flash -->
    <script is:inline>
      function applyTheme() {
        const userPreferredDefault = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches
          ? "dark"
          : "light";
        const savedTheme =
          localStorage.getItem("theme") || userPreferredDefault;
        document.documentElement.setAttribute("data-theme", savedTheme);
      }

      // Apply on initial load
      applyTheme();

      // Apply after page swap to prevent flash
      document.addEventListener("astro:after-swap", applyTheme);
    </script>

    <script is:inline>
      const banner = `
 ██████╗ ██████╗ ███╗   ██╗███████╗ ██████╗ ██╗     ███████╗
██╔════╝██╔═══██╗████╗  ██║██╔════╝██╔═══██╗██║     ██╔════╝
██║     ██║   ██║██╔██╗ ██║███████╗██║   ██║██║     █████╗  
██║     ██║   ██║██║╚██╗██║╚════██║██║   ██║██║     ██╔══╝  
╚██████╗╚██████╔╝██║ ╚████║███████║╚██████╔╝███████╗███████╗
 ╚═════╝ ╚═════╝ ╚═╝  ╚═══╝╚══════╝ ╚═════╝ ╚══════╝╚══════╝
  `;
      console.log(`%c${banner}`, "color: #00ff00; font-weight: bold;");
      console.log(
        "%cThe only console you need is right on the web page 😉",
        "color: #00ff00; background: #111; font-size: 16px; font-weight: bold; padding: 8px 12px; border: 1px solid #00ff00; border-radius: 4px;",
      );
    </script>

    <!-- Resets browser focus after page swap so custom keyboard focus rings don't break after Astro page transitions.  -->
    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
          document.body.focus();
        }
      });
    </script>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{finalTitle}</title>
    <meta name="title" content={finalTitle} />
    <meta name="description" content={description} />

    <!-- Open Graph / Social Cards -->
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_GB" />
    {
      ogImageUrl && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          <meta property="og:image:alt" content={ogImageAlt} />
          {ogImageWidth && (
            <meta property="og:image:width" content={ogImageWidth.toString()} />
          )}
          {ogImageHeight && (
            <meta property="og:image:height" content={ogImageHeight.toString()} />
          )}
        </>
      )
    }
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "profile" && profileFirstName && (
      <meta property="profile:first_name" content={profileFirstName} />
    )}
    {ogType === "profile" && profileLastName && (
      <meta property="profile:last_name" content={profileLastName} />
    )}
    {ogType === "profile" && profileUsername && (
      <meta property="profile:username" content={profileUsername} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={ogImageAlt} />}

    {
      jsonLd.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(
            {
              "@context": "https://schema.org",
              "@graph": jsonLd,
            },
            null,
            2,
          )}
        />
      )
    }

    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Navigation />
    <BackToTop />
    <div class="drafting-frame">
      <div class="terminal-header">
        <div class="terminal-controls" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-title">{terminalPath}</div>
      </div>
      <TerminalBody terminalPath={terminalPath} isSearchable={isSearchable}>
        <div id="content" tabindex="-1">
          <slot />
        </div>
      </TerminalBody>
    </div>
  </body>
</html>

<style>
  html {
    background: var(--bg);
  }

  body {
    background: var(--bg);
    color: var(--text-light);
    font-family: var(--font-mona);
    margin: 0;
    padding: 20px;
    line-height: 1.6;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .skip-link {
    position: absolute;
    top: -48px;
    left: 20px;
    z-index: 1000;
    padding: 8px 12px;
    background: var(--bg);
    color: var(--text-light);
    border: 1px solid var(--accent-color);
    text-decoration: none;
    transition: top 0.2s ease;
  }

  .skip-link:focus,
  .skip-link:focus-visible {
    top: 20px;
  }

  .drafting-frame {
    max-width: 900px;
    margin: 40px auto;
    border: 1px solid var(--border-color);
    padding: 0;
    background: var(--frame-bg);
    position: relative;
    box-shadow:
      0 0 0 1px var(--frame-shadow-1),
      0 0 24px var(--frame-shadow-2),
      inset 0 0 28px var(--frame-shadow-3);
    overflow: hidden;
  }

  html[data-theme="light"] .drafting-frame {
    box-shadow:
      0 0 0 1px var(--frame-shadow-1),
      0 0 18px var(--frame-shadow-2),
      inset 0 0 18px var(--frame-shadow-3);
  }

  .drafting-frame::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 1px solid var(--border-color);
    pointer-events: none;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-color);
    background: var(--header-overlay);
  }

  .terminal-controls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .terminal-dot {
    width: 8px;
    height: 8px;
    border: 1px solid var(--border-color);
    display: inline-block;
  }

  .terminal-dot:nth-child(1) {
    background: var(--dot-orange);
  }

  .terminal-dot:nth-child(2) {
    background: var(--dot-yellow);
  }

  .terminal-dot:nth-child(3) {
    background: var(--dot-green);
  }

  .terminal-title {
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.4px;
  }

  @media (max-width: 768px) {
    .drafting-frame {
      margin: 20px auto;
    }
  }
</style>
