---
import { ClientRouter } from "astro:transitions";
import Navigation from "../components/Navigation.astro";
import "../styles/global.css";
import { SITE_TITLE } from "../consts";
import { Font } from "astro:assets";
import BackToTop from "../components/BackToTop.astro";

interface Props {
  title: string;
  description: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description } = Astro.props;
const terminalPath = `~${Astro.url.pathname}`;
const finalTitle = `${SITE_TITLE} - ${title}`;
---

<html lang="en">
  <head>
    <!-- Global Metadata -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL("rss.xml", Astro.site)}
    />
    <meta name="generator" content={Astro.generator} />

    <Font cssVariable="--font-mona" preload />

    <!-- Apply theme before page renders to prevent flash -->
    <script is:inline>
      function applyTheme() {
        const userPreferredDefault = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches
          ? "dark"
          : "light";
        const savedTheme =
          localStorage.getItem("theme") || userPreferredDefault;
        document.documentElement.setAttribute("data-theme", savedTheme);
      }

      // Apply on initial load
      applyTheme();

      // Apply before page swap to prevent flash
      document.addEventListener("astro:after-swap", applyTheme);
    </script>


    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{finalTitle}</title>
    <meta name="title" content={finalTitle} />
    <meta name="description" content={description} />

    <ClientRouter />
  </head>
  <body>
    <Navigation />
    <BackToTop />
    <div class="drafting-frame">
      <div class="terminal-header">
        <div class="terminal-controls" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-title">{terminalPath}</div>
      </div>
      <div class="terminal-body">
        <div class="terminal-prompt">
          <span class="terminal-prompt-text">$ open {terminalPath}</span>
          <span class="terminal-cursor" aria-hidden="true"></span>
        </div>
        <div class="frame-content">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  html {
    background: var(--bg);
  }

  body {
    background: var(--bg);
    color: var(--text-light);
    font-family: var(--font-mona);
    margin: 0;
    padding: 20px;
    line-height: 1.6;
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  .drafting-frame {
    max-width: 900px;
    margin: 40px auto;
    border: 1px solid var(--border-color);
    padding: 0;
    background: var(--frame-bg);
    position: relative;
    box-shadow:
      0 0 0 1px var(--frame-shadow-1),
      0 0 24px var(--frame-shadow-2),
      inset 0 0 28px var(--frame-shadow-3);
    overflow: hidden;
  }

  html[data-theme="light"] .drafting-frame {
    box-shadow:
      0 0 0 1px var(--frame-shadow-1),
      0 0 18px var(--frame-shadow-2),
      inset 0 0 18px var(--frame-shadow-3);
  }

  .drafting-frame::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 1px solid var(--border-color);
    pointer-events: none;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-color);
    background: var(--header-overlay);
  }

  .terminal-controls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .terminal-dot {
    width: 8px;
    height: 8px;
    border: 1px solid var(--border-color);
    display: inline-block;
  }

  .terminal-dot:nth-child(1) {
    background: var(--dot-orange);
  }

  .terminal-dot:nth-child(2) {
    background: var(--dot-yellow);
  }

  .terminal-dot:nth-child(3) {
    background: var(--dot-green);
  }

  .terminal-title {
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.4px;
  }

  .terminal-body {
    padding: 24px 32px 32px;
  }

  .terminal-prompt {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--accent-color);
    font-size: 12px;
    margin-bottom: 18px;
    border-bottom: 1px dashed var(--border-color);
    padding-bottom: 10px;
  }

  .terminal-prompt-text {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .terminal-cursor {
    width: 8px;
    height: 20px;
    background: var(--accent-color);
    animation: blink 1s steps(1, end) infinite;
    flex: none;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  .frame-content h1,
  .frame-content h2,
  .frame-content h3 {
    color: var(--text-light);
    margin-top: 24px;
    margin-bottom: 12px;
  }

  .frame-content p {
    color: var(--text-light);
    margin: 12px 0;
  }

  .frame-content a {
    color: var(--link-text);
    text-decoration: none;
    border-bottom: 1px dotted var(--link-text);
  }

  .frame-content a:hover {
    color: var(--link-hover);
  }

  .frame-content code {
    background: var(--code-bg);
    padding: 2px 6px;
    font-size: 13px;
    color: var(--code-text);
  }

  @media (max-width: 768px) {
    .drafting-frame {
      margin: 20px auto;
    }

    .terminal-body {
      padding: 16px 20px 20px;
    }
  }
</style>
