---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog" description="All posts" isSearchable={true}>
  <div class="blog-list">
    {
      posts.map((post) => (
        <div
          class="blog-item"
          data-title={post.data.title.toLowerCase()}
          data-desc={post.data.description?.toLowerCase() || ""}
        >
          <a href={`/blog/${post.id}/`}>
            {post.data.heroImage && (
              <Image
                width={510}
                height={255}
                src={post.data.heroImage}
                alt="Hero image"
              />
            )}
            <h3>{post.data.title}</h3>
            <FormattedDate date={post.data.pubDate} />
            <p class="post-desc">{post.data.description}</p>
          </a>
        </div>
      ))
    }
  </div>

  <p id="search-empty-error" class="search-empty-error" style="display: none;">
    [SYSTEM] No entries matched the execution criteria.
  </p>
</Layout>

<script>
  import { searchQuery } from "../../store";

  function initSearch() {
    const blogItems = document.querySelectorAll(".blog-item");
    const errorLog = document.getElementById("search-empty-error");
    const statusBlog = document.getElementById("search-blog-status");

    searchQuery.subscribe((query) => {
      if (!query) {
        if (errorLog) errorLog.style.display = "none";
        blogItems.forEach((item) => {
          (item as HTMLElement).style.display = "block";
        });
      }

      let matchCount = 0;
      blogItems.forEach((item) => {
        const itemHtml = item as HTMLElement;
        const title = itemHtml.dataset.title || "";
        const desc = itemHtml.dataset.desc || "";

        if (title.includes(query) || desc.includes(query)) {
          itemHtml.style.display = "block";
          matchCount++;
        } else {
          itemHtml.style.display = "none";
        }
      });

      if (errorLog) {
        errorLog.style.display =
          matchCount === 0 && query !== "" ? "block" : "none";
      }
    });
  }

  document.addEventListener("astro:page-load", initSearch);
</script>

<style>
  .blog-list {
    display: grid;
    gap: 24px;
  }

  .blog-item {
    border: 1px solid var(--border-color);
    padding: 16px;
    transition: all 0.3s ease;
  }

  .blog-item:hover {
    border-color: var(--accent-color);
    background: rgba(255, 255, 255, 0.02);
  }

  .blog-item a {
    text-decoration: none;
    color: inherit;
    display: block;
    border-bottom: none;
    transition: none;
  }

  .blog-item img {
    width: 100%;
    height: auto;
    margin-bottom: 12px;
    display: block;
  }

  .blog-item h3 {
    margin: 12px 0;
    color: var(--text-light);
    font-size: 16px;
  }

  .post-desc {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 8px;
    margin-bottom: 0;
  }

  .search-empty-error {
    color: var(--dot-orange, #ff5f56);
    font-size: 12px;
    font-family: var(--font-mona);
  }
</style>
