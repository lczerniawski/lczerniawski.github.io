---
import Layout from "../layouts/Layout.astro";
import {
  absoluteUrl,
  pageNodeId,
  siteNodeId,
  siteRootUrl,
  type JsonLdNode,
} from "../lib/jsonld";

const siteUrl = Astro.site!;
const websiteId = siteNodeId(siteUrl, "#website");
const personId = siteNodeId(siteUrl, "#person");
const contactPageUrl = absoluteUrl(siteUrl, "/contact/");

const structuredData: JsonLdNode[] = [
  {
    "@type": "WebSite",
    "@id": websiteId,
    url: siteRootUrl(siteUrl),
    name: "lczerniawski",
    publisher: {
      "@id": personId,
    },
  },
  {
    "@type": "Person",
    "@id": personId,
    url: siteRootUrl(siteUrl),
    name: "Łukasz Czerniawski",
    alternateName: "lczerniawski",
    givenName: "Łukasz",
    familyName: "Czerniawski",
    jobTitle: "Solution Architect",
    description:
      "Solution Architect at AXA focused on security, .NET engineering, Python and applied AI.",
    knowsLanguage: "en-GB",
    image: {
      "@type": "ImageObject",
      "@id": siteNodeId(siteUrl, "#person-image"),
      url: absoluteUrl(siteUrl, "/lukasz_czerniawski_photo.jpg"),
      caption: "Łukasz Czerniawski",
    },
    sameAs: [
      "https://github.com/lczerniawski",
      "https://www.linkedin.com/in/lczerniawski",
    ],
  },
  {
    "@type": "ContactPage",
    "@id": pageNodeId(siteUrl, "/contact/", "#webpage"),
    url: contactPageUrl,
    isPartOf: {
      "@id": websiteId,
    },
    name: "Contact",
    inLanguage: "en-GB",
    about: {
      "@id": personId,
    },
    breadcrumb: {
      "@id": pageNodeId(siteUrl, "/contact/", "#breadcrumb"),
    },
  },
  {
    "@type": "BreadcrumbList",
    "@id": pageNodeId(siteUrl, "/contact/", "#breadcrumb"),
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteRootUrl(siteUrl),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Contact",
        item: contactPageUrl,
      },
    ],
  },
];
---

<Layout
  title="Contact"
  description="Get in touch with me"
  jsonLd={structuredData}
  ogType="profile"
  ogImage="/lukasz_czerniawski_photo.jpg"
  profileFirstName="Łukasz"
  profileLastName="Czerniawski"
  profileUsername="lczerniawski"
>
  <section class="profile-section">
    <h2 class="header">Contact</h2>
    <p>
      Whether you want to discuss system architecture, security, AI, or just
      talk about open-source, feel free to reach out.
    </p>
  </section>

  <section class="channels-section">
    <h2 class="header">Channels</h2>
    <ul class="square-list contact-list">
      <li>
        <strong>Email:</strong>
        <a href="mailto:l.czerniawski@icloud.com">l.czerniawski@icloud.com</a>
      </li>
      <li>
        <strong>GitHub:</strong>
        <a
          href="https://github.com/lczerniawski"
          target="_blank"
          rel="noopener noreferrer">github.com/lczerniawski</a
        >
      </li>
      <li>
        <strong>LinkedIn:</strong>
        <a
          href="https://www.linkedin.com/in/lczerniawski"
          target="_blank"
          rel="noopener noreferrer">linkedin.com/in/lczerniawski</a
        >
      </li>
    </ul>
  </section>
</Layout>

<style>
  .header {
    margin-bottom: 0px;
  }

  .channels-section {
    margin-top: 35px;
  }

  .square-list {
    list-style: none;
    padding-left: 0;
    margin-top: 0;
  }

  .square-list li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 12px;
    padding-bottom: 5px;
    color: var(--text-light);
  }

  .square-list li::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 9px;
    width: 6px;
    height: 6px;
    background-color: var(--accent-color);
  }

  .contact-list strong {
    font-weight: 600;
    margin-right: 4px;
    font-family: var(--font-mona);
    font-size: 13px;
    color: var(--text-muted);
  }

  .contact-list a {
    font-size: 14px;
  }
</style>
