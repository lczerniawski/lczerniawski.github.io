---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION } from "../consts";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<Layout title=`Home` description={SITE_DESCRIPTION}>
  <main>
    <h2>Welcome</h2>
    <p>
      I'm a Solution Architect at AXA working on security, .NET, Python, and
      applied AI. This is my personal space for projects, thoughts, technical
      explorations, guides.
      <br />
      The opinions are my own.
    </p>

    <h3>Latest Posts</h3>
    <div class="posts-grid">
      {
        posts.map((post) => (
          <article class="post-card">
            <h4>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h4>
            <p>{post.data.description}</p>
            <a href={`/blog/${post.id}/`} class="read-more">
              Read more →
            </a>
          </article>
        ))
      }
    </div>

    <p class="all-posts">
      <a href="/blog/">View all posts →</a>
    </p>
  </main>
</Layout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin: 24px 0;
  }

  .post-card {
    border: 1px solid var(--border-color);
    padding: 16px;
  }

  .post-card h4 {
    margin: 0 0 8px 0;
    font-size: 16px;
  }

  .post-card h4 a {
    color: var(--accent-color);
    text-decoration: none;
  }

  .post-card h4 a:hover {
    color: var(--accent-hover);
  }

  .post-card p {
    margin: 12px 0;
    color: var(--text-light);
    font-size: 14px;
  }

  .read-more {
    color: var(--link-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }

  .read-more:hover {
    color: var(--link-hover);
  }

  .all-posts {
    margin-top: 32px;
  }
</style>
