---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION } from "../consts";
import {
  absoluteUrl,
  pageNodeId,
  siteNodeId,
  siteRootUrl,
  type JsonLdNode,
} from "../lib/jsonld";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
const siteUrl = Astro.site!;
const websiteId = siteNodeId(siteUrl, "#website");
const personId = siteNodeId(siteUrl, "#person");

const structuredData: JsonLdNode[] = [
  {
    "@type": "WebSite",
    "@id": websiteId,
    url: siteRootUrl(siteUrl),
    name: "lczerniawski",
    alternateName: ["Łukasz Czerniawski", "lczerniawski.github.io"],
    description: SITE_DESCRIPTION,
    inLanguage: "en-GB",
    image: {
      "@type": "ImageObject",
      "@id": siteNodeId(siteUrl, "#website-image"),
      url: absoluteUrl(siteUrl, "/favicon.svg"),
      caption: "lczerniawski site mark",
    },
    publisher: {
      "@id": personId,
    },
  },
  {
    "@type": "Person",
    "@id": personId,
    url: siteRootUrl(siteUrl),
    name: "Łukasz Czerniawski",
    alternateName: "lczerniawski",
    givenName: "Łukasz",
    familyName: "Czerniawski",
    jobTitle: "Solution Architect",
    description:
      "Solution Architect at AXA focused on security, .NET engineering, Python and applied AI.",
    knowsLanguage: "en-GB",
    image: {
      "@type": "ImageObject",
      "@id": siteNodeId(siteUrl, "#person-image"),
      url: absoluteUrl(siteUrl, "/lukasz_czerniawski_photo.jpg"),
      caption: "Łukasz Czerniawski",
    },
    sameAs: [
      "https://github.com/lczerniawski",
      "https://www.linkedin.com/in/lczerniawski",
    ],
  },
];
---

<Layout
  title="Home"
  description={SITE_DESCRIPTION}
  jsonLd={structuredData}
  ogType="profile"
  ogImage="/lukasz_czerniawski_photo.jpg"
  profileFirstName="Łukasz"
  profileLastName="Czerniawski"
  profileUsername="lczerniawski"
>
  <main>
    <div id="cursor"></div>
    <h2 class="typed" data-cursor="big">Welcome</h2>
    <p class="typed" data-cursor="small">
      I'm a Solution Architect at AXA working on security, .NET, Python, and
      applied AI.
      <br />
      This is my personal space for projects, thoughts, technical explorations, guides.
      <br />
      The opinions are my own.
    </p>

    <div id="posts">
      <h3>Latest Posts</h3>
      <div class="posts-grid">
        {
          posts.map((post) => (
            <article class="post-card">
              <h4>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h4>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.id}/`} class="read-more">
                Read more →
              </a>
            </article>
          ))
        }
      </div>

      <p class="all-posts">
        <a href="/blog/">View all posts →</a>
      </p>
    </div>
  </main>
</Layout>

<script>
  import { stagger, splitText, createTimeline } from "animejs";
  import {
    isMainCursorVisible,
    isWritingTerminalAnimationFinished,
  } from "../store";

  const unsubscribe = isWritingTerminalAnimationFinished.subscribe((value) => {
    if (value) {
      const posts = document.getElementById("posts");
      const targets = document.querySelectorAll(".typed");
      const cursor = document.getElementById("cursor");

      const t1 = createTimeline();

      targets.forEach((target) => {
        const { chars } = splitText(target, { words: true, chars: true });
        chars.forEach((char) => (char.style.opacity = "0"));

        t1.add(chars, {
          opacity: [{ from: 0, to: 1, duration: 1 }],
          delay: stagger(25),
          loop: false,
          onBegin: () => {
            const cursorSize = target.getAttribute("data-cursor");
            if (cursorSize === "big") {
              if (cursor) {
                cursor.classList.remove("cursor-small");
                cursor.classList.add("cursor-big");
              }
            }

            if (cursorSize === "small") {
              if (cursor) {
                cursor.classList.remove("cursor-big");
                cursor.classList.add("cursor-small");
              }
            }
          },
          onUpdate: () => {
            const visibleChars = chars.filter(
              (char) => char.style.opacity === "1",
            );
            const lastChar = visibleChars[visibleChars.length - 1];

            if (lastChar) {
              lastChar.after(cursor);
            }
          },
        });
      });

      t1.onBegin = () => {
        if (cursor) cursor.style.display = "inline-block";
        if (targets) {
          targets.forEach((target) => {
            target.classList.add("is-visible");
          });
        }
        isMainCursorVisible.set(false);
        unsubscribe();
      };

      t1.onComplete = () => {
        if (cursor) cursor.style.display = "none";
        if (posts) {
          posts.style.opacity = "1";
          posts.style.transform = "translateY(0px)";
        }
        isMainCursorVisible.set(true);
      };
    }
  });

  document.addEventListener("astro:before-swap", () => {
    isMainCursorVisible.set(true);
  });

  document.addEventListener("astro:after-swap", () => {
    const posts = document.getElementById("posts");
    const targets = document.querySelectorAll(".typed");

    if (posts) posts.classList.add("is-visible");
    if (targets) {
      targets.forEach((target) => {
        target.classList.add("is-visible");
      });
    }
  });
</script>

<style>
  #cursor {
    width: 10px;
    background-color: var(--accent-color);
    display: none;
    position: relative;
  }

  .cursor-small {
    height: 30px;
    top: 10px;
  }

  .cursor-big {
    height: 40px;
    top: 12px;
  }

  .typed {
    opacity: 0;
  }

  .typed.is-visible {
    opacity: 1;
  }

  #posts {
    opacity: 0;
    transform: translateY(100%);
    transition:
      transform 0.3s ease-out,
      opacity 0.3s ease-out;
  }

  #posts.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin: 24px 0;
  }

  .post-card {
    border: 1px solid var(--border-color);
    padding: 16px;
  }

  .post-card h4 {
    margin: 0 0 8px 0;
    font-size: 16px;
  }

  .post-card h4 a {
    color: var(--accent-color);
    text-decoration: none;
  }

  .post-card h4 a:hover {
    color: var(--accent-hover);
  }

  .post-card p {
    margin: 12px 0;
    color: var(--text-light);
    font-size: 14px;
  }

  .read-more {
    color: var(--link-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }

  .read-more:hover {
    color: var(--link-hover);
  }

  .all-posts {
    margin-top: 32px;
  }
</style>
